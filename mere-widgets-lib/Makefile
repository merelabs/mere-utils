	$(COPY_FILE) --parents src/merewidgetresizer.cpp src/merepushmenu.cpp src/mereballonwidget.cpp src/merelabel.cpp src/mereclickdetector.cpp src/mereshadowwidget.cpp $(DISTDIR)/


