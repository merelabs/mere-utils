mere-utils.pro:
qmake: FORCE
	@$(QMAKE) -o Makefile mere-utils.pro

qmake_all: sub-mere-utils-lib-qmake_all sub-mere-utils-app-qmake_all sub-mere-utils-test-qmake_all FORCE

make_first: sub-mere-utils-lib-make_first-ordered sub-mere-utils-app-make_first-ordered sub-mere-utils-test-make_first-ordered  FORCE
all: sub-mere-utils-lib-all-ordered sub-mere-utils-app-all-ordered sub-mere-utils-test-all-ordered  FORCE
clean: sub-mere-utils-lib-clean-ordered sub-mere-utils-app-clean-ordered sub-mere-utils-test-clean-ordered  FORCE
distclean: sub-mere-utils-lib-distclean-ordered sub-mere-utils-app-distclean-ordered sub-mere-utils-test-distclean-ordered  FORCE
	-$(DEL_FILE) Makefile
install_subtargets: sub-mere-utils-lib-install_subtargets-ordered sub-mere-utils-app-install_subtargets-ordered sub-mere-utils-test-install_subtargets-ordered FORCE
uninstall_subtargets: sub-mere-utils-lib-uninstall_subtargets-ordered sub-mere-utils-app-uninstall_subtargets-ordered sub-mere-utils-test-uninstall_subtargets-ordered FORCE

sub-mere-utils-lib-check_ordered:
	@test -d mere-utils-lib/ || mkdir -p mere-utils-lib/
	cd mere-utils-lib/ && ( test -e Makefile || $(QMAKE) -o Makefile /usr/home/iklash/workspace/mere/mere-utils/mere-utils-lib/mere-utils-lib.pro ) && $(MAKE) -f Makefile check
sub-mere-utils-app-check_ordered: sub-mere-utils-lib-check_ordered 
	@test -d mere-utils-app/ || mkdir -p mere-utils-app/
	cd mere-utils-app/ && ( test -e Makefile || $(QMAKE) -o Makefile /usr/home/iklash/workspace/mere/mere-utils/mere-utils-app/mere-utils-app.pro ) && $(MAKE) -f Makefile check
